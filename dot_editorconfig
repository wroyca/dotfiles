# https://editorconfig.org
#
# Note that EditorConfig does not have a formal concept of a global configuration.
# Instead, it searches upward through the directory tree from the current file's
# directory until it encounters a configuration file with root = true. From there,
# it applies settings downwards. For background on this behavior, see
# https://github.com/editorconfig/editorconfig/issues/465.
#
root = true

# Default indentation to 2 spaces.
#
# Using 4 spaces consumes too much horizontal space, especially when nesting
# lambdas or complex conditionals. Eight is obviously out of the question.
# We also enforce general hygiene: trailing whitespace is just noise in diffs
# and a missing trailing newline at EOF confuses older POSIX tools (like cat).
#
[*]
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Disable trailing whitespace trimming for Markdown.
#
# Unlike regular source code, Markdown relies on two trailing spaces to denote
# a hard line break (<br>). Stripping them silently breaks the rendered document.
# While we could use explicit <br> HTML tags, doing so degrades the readability
# of the raw text. So we tolerate the invisible characters here.
#
[*.md]
trim_trailing_whitespace = false

# Force CRLF line endings for Windows Batch files to avoid the 512-byte boundary bug.
#
# The cmd.exe parser reads batch files in 512-byte chunks and calculates offsets
# assuming 2-byte (CRLF) line endings. If we use Unix (LF) line endings and a
# label (:) straddles this block boundary, the parser miscalculates, misses the
# newline, and either fails to jump or treats the label as part of the previous
# command. The reliable workaround is to give the parser the CRLF it expects.
#
[*.bat]
end_of_line = crlf
