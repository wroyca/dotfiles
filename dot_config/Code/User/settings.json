{
  // Breadcrumbs
  //
  "breadcrumbs.enabled": false,

  // Chat
  //
  "chat.agent.enabled": false,
  "chat.disableAIFeatures": true,

  // Clangd
  //
  "clangd.arguments": [
    "--all-scopes-completion=true",
    "--background-index=true",
    "--background-index-priority=normal",
    "--clang-tidy=true",
    "--completion-parse=always",
    "--ranking-model=decision_forest",
    "--completion-style=bundled",
    "--function-arg-placeholders=0",
    "--header-insertion=never",
    "--pch-storage=memory",
    "--parse-forwarding-functions"
  ],

  // Diff Editor
  //
  "diffEditor.codeLens": true,
  "diffEditor.experimental.showMoves": true,
  "diffEditor.experimental.useTrueInlineView": true,
  "diffEditor.hideUnchangedRegions.enabled": true,
  "diffEditor.ignoreTrimWhitespace": false,

  // Editor
  //
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.acceptSuggestionOnEnter": "off",
  "editor.bracketPairColorization.enabled": false,
  "editor.codeLens": false,
  "editor.codeLensFontFamily": "MonoLisa",
  "editor.comments.ignoreEmptyLines": false,
  "editor.cursorSurroundingLines": 4,
  "editor.cursorSurroundingLinesStyle": "all",
  "editor.fontFamily": "MonoLisa",
  "editor.fontLigatures": "'liga' off, 'calt' on, 'ss02' on",
  "editor.fontSize": 16,
  "editor.fontWeight": 400,
  "editor.formatOnType": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.inlineSuggest.enabled": false,
  "editor.inlineSuggest.syntaxHighlightingEnabled": false,
  "editor.lightbulb.enabled": "off",
  "editor.lineHeight": 1.6,
  "editor.linkedEditing": true,
  "editor.minimap.enabled": false,
  "editor.mouseWheelScrollSensitivity": 3,
  "editor.mouseWheelZoom": true,
  "editor.overviewRulerBorder": false,
  "editor.padding.bottom": 10,
  "editor.padding.top": 10,
  "editor.renderWhitespace": "trailing",
  "editor.rulers": [
    80
  ],
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "hidden",
  "editor.scrollbar.verticalScrollbarSize": 0,
  "editor.smoothScrolling": true,
  "editor.stablePeek": true,
  "editor.stickyScroll.enabled": false,
  "editor.suggest.showIcons": false,
  "editor.tabSize": 2,
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "comment",
        "settings": {
          "fontStyle": "italic"
        }
      }
    ]
  },

  // Explorer
  //
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  "explorer.confirmUndo": "verbose",
  "explorer.decorations.colors": false,
  "explorer.enableUndo": false,
  "explorer.incrementalNaming": "smart",
  "explorer.sortOrderLexicographicOptions": "upper",

  // Extensions
  //
  "extensions.ignoreRecommendations": true,

  // Files
  //
  "files.autoGuessEncoding": true,
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,

  // Git
  //
  "git.autofetch": true,
  "git.defaultCloneDirectory": "~/Projects",

  // Github Copilot
  //
  "github.copilot.chat.codesearch.enabled": false,
  "github.copilot.nextEditSuggestions.enabled": false,
  "github.copilot.nextEditSuggestions.fixes": false,
  "github.copilot.chat.summarizeAgentConversationHistory.enabled": false,

  // GitHub Pull Requests
  //
  "githubPullRequests.assignCreated": "${user}",
  "githubPullRequests.codingAgent.autoCommitAndPush": false,
  "githubPullRequests.codingAgent.enabled": false,
  "githubPullRequests.codingAgent.promptForConfirmation": false,
  "githubPullRequests.codingAgent.uiIntegration": false,
  "githubPullRequests.defaultMergeMethod": "rebase",
  "githubPullRequests.experimental.chat": true,
  "githubPullRequests.experimental.useQuickChat": true,
  "githubPullRequests.notifications": "pullRequests",
  "githubPullRequests.quickDiff": true,
  "githubPullRequests.showPullRequestNumberInTree": true,
  "githubPullRequests.terminalLinksHandler": "vscode",

  // Inline Chat
  //
  "inlineChat.enableV2": true,

  // Outline
  //
  "outline.problems.colors": false,

  // Project manager
  //
  "projectManager.ignoreProjectsWithinProjects": true,
  "projectManager.git.baseFolders": [
    "~/Projects",
    "~/.local/share/chezmoi"
  ],

  // Scm
  //
  "scm.alwaysShowRepositories": true,
  "scm.diffDecorations": "gutter",
  "scm.repositories.selectionMode": "single",
  "scm.showInputActionButton": false,

  // Search
  //
  "search.decorations.badges": false,
  "search.decorations.colors": false,
  "search.maxResults": null,

  // Security
  //
  "security.workspace.trust.enabled": false,

  // Terminal
  //
  "terminal.external.linuxExec": "kitty",
  "terminal.integrated.confirmOnExit": "hasChildProcesses",
  "terminal.integrated.copyOnSelection": false, // Bug: some actions induce unwanted selection.
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.defaultProfile.linux": "fish",
  "terminal.integrated.enableImages": true,
  "terminal.integrated.enableKittyKeyboardProtocol": true,
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.hideOnStartup": "always",
  "terminal.integrated.ignoreProcessNames": [
    "bash",
    "fish",
    "starship"
  ],
  // "terminal.integrated.middleClickBehavior": "paste", // Bug: duplicate paste.
  "terminal.integrated.minimumContrastRatio": 7,
  "terminal.integrated.mouseWheelScrollSensitivity": 3,
  "terminal.integrated.mouseWheelZoom": true,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.shellIntegration.decorationsEnabled": "never",
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.stickyScroll.enabled": true,
  "terminal.integrated.suggest.enabled": false, // Trust me, you don't want this.
  "terminal.integrated.tabStopWidth": 2,

  // Window
  //
  "window.autoDetectColorScheme": true,
  "window.controlsStyle": "hidden",
  "window.dialogStyle": "custom",
  "window.menuBarVisibility": "toggle",
  "window.titleBarStyle": "custom",
  "window.zoomLevel": 1.0001, // https://github.com/microsoft/vscode/issues/224714

  // Workbench
  //
  "workbench.colorTheme": "Visual Studio Dark",
  "workbench.commandPalette.experimental.suggestCommands": true,
  "workbench.commandPalette.showAskInChat": false,
  "workbench.editor.decorations.colors": false,
  "workbench.editor.empty.hint": "hidden",
  "workbench.editor.useModal": "off",
  "workbench.iconTheme": "vs-minimal", // https://github.com/microsoft/vscode/issues/141428
  "workbench.layoutControl.enabled": false,
  "workbench.list.mouseWheelScrollSensitivity": 3,
  "workbench.list.smoothScrolling": true,
  "workbench.localHistory.maxFileEntries": 1000,
  "workbench.localHistory.maxFileSize": 1024,
  "workbench.navigationControl.enabled": false,
  "workbench.preferredDarkColorTheme": "Modus Vivendi",
  "workbench.preferredLightColorTheme": "Modus Operandi",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.settings.alwaysShowAdvancedSettings": true,
  "workbench.settings.showAISearchToggle": false,
  "workbench.startupEditor": "none",
  "workbench.statusBar.visible": true,
  "workbench.tips.enabled": false,
  "workbench.welcomePage.walkthroughs.openOnInstall": false,

  // ZenMode
  //
  "zenMode.fullScreen": false,
}
