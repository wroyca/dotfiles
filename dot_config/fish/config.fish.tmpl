# Suppress the default fish greeting. We do this by overriding the 
# fish_greeting function with an empty definition, as the default 
# message is mostly visual noise.
#
function fish_greeting
end

# Specify the location of the Starship configuration file. We prefer 
# to keep it neatly tucked away in a dedicated subdirectory rather 
# than cluttering the root config directory.
#
set -gx STARSHIP_CONFIG $HOME/.config/starship/starship.toml

# It appears Git Credential Manager (GCM) stopped honoring the 
# `credentialStore` setting directly from the git config.
#
# Rather than spending time trying to debug the exact cause of this 
# regression, we force the setting via the environment variable. It 
# turns out this is the only mechanism GCM still reliably respects.
#
set -gx GCM_CREDENTIAL_STORE cache

# Silence Wine and DXVK diagnostics. By default, both are notoriously 
# noisy and will quickly pollute the terminal output, so we shut them 
# up entirely.
#
set -gx WINEDEBUG -all
set -gx DXVK_LOG_LEVEL none

# Provide a convenience toggle for Wine debug output. Since we globally 
# disable Wine diagnostics above, it is handy to have a quick way to flip 
# them back on when troubleshooting specific prefix issues.
#
function toggle_wine_debug
  if test "$WINEDEBUG" = "-all"
    set -gx WINEDEBUG ""
    echo "Wine debug: enabled"
  else
    set -gx WINEDEBUG -all
    echo "Wine debug: disabled"
  end
end

# Load user-specific aliases. Note that we keep these in a separate 
# file to prevent the main configuration from becoming unwieldy as the 
# list of aliases grows.
#
source ~/.config/fish/alias.fish

# Initialize the Starship cross-shell prompt (https://starship.rs/). 
# Note that this needs to happen at the very end of the configuration 
# so it can properly hook into the shell's prompt rendering mechanism.
#
starship init fish | source
