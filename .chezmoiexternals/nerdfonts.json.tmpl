{{- $latestRelease := gitHubLatestRelease "ryanoasis/nerd-fonts" -}}
{{- if not $latestRelease -}}
{{-   fail "Failed to retrieve Nerd Fonts release information from GitHub API" -}}
{{- end -}}

{{- $nerdFontsVersion := $latestRelease.TagName | toString -}}
{{- if not $nerdFontsVersion -}}
{{-   fail "Invalid or missing version tag in GitHub release metadata" -}}
{{- end -}}

{{- $fontInstallPath := ".local/share/fonts/NerdFonts" -}}
{{- $distributionUrl := printf "https://github.com/ryanoasis/nerd-fonts/releases/download/%s/NerdFontsSymbolsOnly.zip" $nerdFontsVersion -}}

{
  "{{ $fontInstallPath }}": {
    "url": "{{ $distributionUrl }}",
    "type": "archive",
    "refreshPeriod": "24h",
    "stripComponents": 0,
    "include": [
      "*.ttf",
      "*.otf",
      "*.woff",
      "*.woff2"
    ],
    "exclude": [
      "*.txt",
      "*.md",
      "*.rst",
      "*.html",
      "*.pdf",
      "license*",
      "LICENSE*",
      "readme*",
      "README*"
    ]
  }
}
