{{- $baseUrl := "https://download.build2.org" -}}

{{- /* Fetch the build2 version from toolchain.sha256 */ -}}
{{- $toolchainSha256 := output "curl" "-s" (printf "%s/toolchain.sha256" $baseUrl) | trim -}}
{{- if not $toolchainSha256 -}}
{{-   fail "Failed to retrieve build2 toolchain version information" -}}
{{- end -}}

{{- /* Extract the version without brittle string splitting */ -}}
{{- $build2Version := index (splitList "\n" $toolchainSha256) 0 | trimPrefix "# " | trim -}}

{{- /* Path for Linux x86_64 */ -}}
{{- $bindistPath := "bindist/linux/linux-glibc2.31/x86_64" -}}
{{- $packagesUrl := printf "%s/%s/%s/packages.sha256" $baseUrl $build2Version $bindistPath -}}

{{- /* Fetch the exact package filename from packages.sha256 */ -}}
{{- $packagesSha256 := output "curl" "-s" $packagesUrl | trim -}}
{{- if not $packagesSha256 -}}
{{-   fail "Failed to retrieve build2 packages checksum information" -}}
{{- end -}}

{{- $packageLine := "" -}}
{{- range (splitList "\n" $packagesSha256) -}}
{{-   if and (contains ".tar.xz" .) (contains "build2-toolchain" .) -}}
{{-     $packageLine = . -}}
{{-     break -}}
{{-   end -}}
{{- end -}}

{{- if not $packageLine -}}
{{-   fail "Failed to find build2-toolchain package in packages.sha256" -}}
{{- end -}}

{{- $packageName := last (splitList "*" $packageLine) | trim -}}
{{- $distributionUrl := printf "%s/%s/%s/%s" $baseUrl $build2Version $bindistPath $packageName -}}

{{/* https://build2.org/ */}}
{
  ".local": {
    "url": "{{ $distributionUrl }}",
    "type": "archive",
    "refreshPeriod": "24h",
    "executable": true,
    "stripComponents": 1
  }
}
