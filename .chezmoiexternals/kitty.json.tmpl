{{- $latestRelease := gitHubLatestRelease "kovidgoyal/kitty" -}}
{{- if not $latestRelease -}}
{{-   fail "Failed to retrieve Kitty release information from GitHub API" -}}
{{- end -}}

{{- $kittyVersion := $latestRelease.TagName | toString -}}
{{- if not $kittyVersion -}}
{{-   fail "Invalid or missing version tag in GitHub release metadata" -}}
{{- end -}}

{{- $cleanVersion := regexReplaceAll "^v" $kittyVersion "" -}}
{{- $distributionUrl := printf "https://github.com/kovidgoyal/kitty/releases/download/%s/kitty-%s-x86_64.txz" $kittyVersion $cleanVersion -}}

{
  ".local": {
    "url": "{{ $distributionUrl }}",
    "type": "archive",
    "refreshPeriod": "24h",
    "executable": true
  }
}
