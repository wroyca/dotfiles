#!/bin/bash

{{ if eq .osid "linux-fedora" }}
  sudo dnf install -y \
    gnome-tweaks

  sudo dnf install -y \
    adw-gtk3-theme

  sudo dnf install -y \
    kitty

  sudo dnf install -y \
    fish

  sudo dnf copr enable -y \
    agriffis/neovim-nightly

  sudo dnf install -y \
    neovim

  sudo rpm -v --import \
    https://download.sublimetext.com/sublimehq-rpm-pub.gpg

  sudo dnf config-manager --add-repo \
    https://download.sublimetext.com/rpm/stable/x86_64/sublime-text.repo

  sudo dnf install -y \
    sublime-text

  sudo dnf install -y \
    sublime-merge
{{ end }}
