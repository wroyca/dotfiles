#!/bin/sh

if [ ! -f "{{ .chezmoi.homeDir }}/.config/age/key.txt" ]; then

mkdir -p                       "{{ .chezmoi.homeDir }}/.config/age"
chezmoi age decrypt --output "{{ .chezmoi.homeDir }}/.config/age/key.txt" --passphrase "{{ .chezmoi.sourceDir }}/private_dot_config/age/key.txt.age"
chmod 600                      "{{ .chezmoi.homeDir }}/.config/age/key.txt"

fi
