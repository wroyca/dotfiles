#!/bin/bash

alias v='nvim'

# Fedora ships vim-minimal by default. Although the resulting binary is named
# vi, this is still unquestionably Vim - just in vi compatibility mode by
# default.
#
alias vim='vi'

# Interactive mode aliases for common file manipulation commands.
#
# https://man.openbsd.org/cp#i
# https://man.openbsd.org/cp#v
# https://man.openbsd.org/mv#i
# https://man.openbsd.org/mv#v
# https://man.openbsd.org/rm#i
# https://man.openbsd.org/rm#v
#
alias cp='cp -iv'
alias mv='mv -iv'
alias rm='rm -iv'

# https://man.openbsd.org/mkdir#p
# https://man.openbsd.org/mkdir#v
# https://man.archlinux.org/man/ls.1.en#hyperlink
# https://man.archlinux.org/man/extra/tree/tree.1.en#filesfirst
#
alias mkdir='mkdir -pv'
alias ls='ls --hyperlink'
alias tree='tree --filesfirst'
